  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns",
      "deno.unstable"
    ]
  },
  "unstable": [
    "kv",
    "otel",
    "temporal",
    "sloppy-imports"
  ],
  "nodeModulesDir": "auto",
  "exclude": [
    ".claude/skills/",
    ".claude/worktrees/",
    ".github/",
    "asset-cdn/",
    "drizzle/",
    "node_modules/",
    "web-next/dist/",
    "web-next/node_modules/",
    "web-next/.output/",
    "web-next/.nitro/",
    "web-next/storybook-static/",
    "web-next/vite.config.ts",
    "patches/",
    "types/"
  ],
  "fmt": {
    "exclude": [
      "*.md",
      "*.yaml",
      "*.yml",
      "**/*.md",
      "**/*.yaml",
      "**/*.yml",
      ".agents/skills/",
      ".agents/commands/",
      ".claude/skills/",
      ".claude/commands/",
      "ai/prompts/",
      "graphql/locales/markdown/*.md",
      "graphql/locales/search/*.md"
    ]
  },
  "lint": {
    "rules": {
      "exclude": [
        "require-await",
        "no-window",
        "no-window-prefix"
      ]
    }
  },
  "tasks": {
    "install": "mise install",
    "fmt": "mise run fmt",
    "check": "mise run check",
    "test": "mise run test",
    "drizzle-kit": "deno run -A drizzle-kit",
    "next:codegen": "mise run next:codegen"
  }
}
