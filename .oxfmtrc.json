{
  "arrowParens": "always",
  "bracketSameLine": false,
  "bracketSpacing": true,
  "embeddedLanguageFormatting": "off",
  "endOfLine": "lf",
  "insertFinalNewline": true,
  "jsxSingleQuote": false,
  "objectWrap": "preserve",
  "printWidth": 80,
  "quoteProps": "as-needed",
  "semi": true,
  "singleAttributePerLine": false,
  "singleQuote": false,
  "trailingComma": "all",
  "tabWidth": 2,
  "useTabs": false,
  "sortPackageJson": false,
  "ignorePatterns": [
    ".agents/**",
    ".claude/**",
    ".github/**",
    "ai/prompts/**",
    "drizzle/**",
    "patches/**",
    "**/__generated__/**",
    "**/.output/**",
    "**/.nitro/**",
    "**/dist/**",
    "**/node_modules/**",
    "**/storybook-static/**",
    "**/*.md",
    "**/*.po",
    "**/*.toml",
    "**/*.yaml",
    "**/*.yml",
    "deno.json",
    "graphql/schema.graphql",
    "pnpm-lock.yaml"
  ]
}
