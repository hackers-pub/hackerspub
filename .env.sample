MODE=development # development, test, production
ORIGIN=https://example.com  # base url of server
API_URL=http://localhost:8080/graphql  # Standalone GraphQL endpoint for web-next
DATABASE_URL=postgresql://localhost/hackerspub
KV_URL=redis://localhost:6379/0
SECRET_KEY=  # openssl rand -hex 32
INSTANCE_ACTOR_KEY=  # mise run keygen
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_SUBJECT=https://example.com/
BEHIND_PROXY=false
DRIVE_DISK=fs  # fs or s3
# In case of fs:
FS_LOCATION=./media
# In case of s3:
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_CDN_URL=
# S3_BUCKET=
# AWS_REGION=
MAILGUN_KEY=
MAILGUN_REGION=us
MAILGUN_DOMAIN=
MAILGUN_FROM=
ANTHROPIC_API_KEY=
GOOGLE_GENERATIVE_AI_API_KEY=
PLAUSIBLE=false
SENTRY_DSN=  # web-next injects this at runtime for the server and client
LOG_QUERY=false
LOG_FEDIFY=false
# graphql requires EMAIL_FROM or MAILGUN_FROM
EMAIL_FROM=admin@example.com
FUTURE_TIMESTAMP_TOLERANCE=300000
APNS_TEAM_ID=
APNS_KEY_ID=
APNS_SIGNING_KEY=
APNS_DEFAULT_TOPIC=
# APNS_HOST=api.sandbox.push.apple.com
# Firebase *service account* JSON, base64-encoded. This is the Admin SDK
# private key (Firebase Console -> Project Settings -> Service Accounts ->
# Generate new private key), NOT the Android `google-services.json` client
# config. Despite the variable name, the file must contain `private_key`,
# `client_email`, and `project_id`; a `google-services.json` (with
# `project_info`/`mobilesdk_app_id`) lacks `private_key` and will not work.
# Generate with: `base64 -i path/to/serviceAccountKey.json | tr -d '\n'`
GOOGLE_SERVICES_JSON_BASE64=
