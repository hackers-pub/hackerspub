{
  "version": "0.2.0",
  "configurations": [
    {
      "request": "launch",
      "name": "GraphQL API (Node.js)",
      "type": "node",
      "program": "${workspaceFolder}/graphql/main.node.ts",
      "cwd": "${workspaceFolder}/graphql/",
      "env": {},
      "runtimeExecutable": "node",
      "runtimeArgs": [
        "--enable-source-maps",
        "--import",
        "temporal-polyfill/global",
        "--import",
        "./instrument.node.ts",
        "--inspect-wait=127.0.0.1:9228"
      ],
      "args": ["--allow-file-kv"]
    },
    {
      "request": "launch",
      "name": "GraphQL API (Deno rollback)",
      "type": "node",
      "program": "${workspaceFolder}/graphql/main.ts",
      "cwd": "${workspaceFolder}/graphql/",
      "env": {},
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "-A",
        "--unstable-cron",
        "--env-file=../.env",
        "--inspect-wait=127.0.0.1:9229"
      ],
      "args": ["--allow-file-kv"],
      "attachSimplePort": 9229
    },
    {
      "request": "launch",
      "name": "GraphQL worker",
      "type": "node",
      "program": "${workspaceFolder}/graphql/worker.ts",
      "cwd": "${workspaceFolder}/graphql/",
      "env": {},
      "runtimeExecutable": "deno",
      "runtimeArgs": [
        "run",
        "-A",
        "--unstable-cron",
        "--env-file=../.env",
        "--inspect-wait=127.0.0.1:9230"
      ],
      "attachSimplePort": 9230
    }
  ]
}
